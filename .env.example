# Copy this file to `.env` and fill in the API keys you want to use locally.
# The web server reads `.env` at runtime, but the real file is intentionally ignored by Git.

# Google Gemini API Key
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# OpenAI API Key (optional)
# OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"

# Alibaba Qwen API Key (optional)
# DASHSCOPE_API_KEY="YOUR_QWEN_API_KEY_HERE"
